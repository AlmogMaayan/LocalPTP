{
  "name": "localptp",
  "version": "0.1.0",
  "description": "LocalCode Orchestrator CLI — drives a local coding model over large codebases.",
  "type": "module",
  "bin": {
    "localptp": "dist/cli.js",
    "localcoder": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
